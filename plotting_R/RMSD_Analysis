# You can control the FACET plot and MEAN plot separately.
#
# ============================================================
# 1) Faceted plot reference lines
# ============================================================
# These appear ONLY in the faceted plot:
#   - individual replicate traces
#   - mean trace inside each structure panel
#
# No lines:
#   facet_ref_line_y <- NA
#   facet_ref_line_x <- NA
#
# One line:
#   facet_ref_line_y <- 10
#   facet_ref_line_x <- 50
#
# Multiple lines:
#   facet_ref_line_y <- c(10, 15, 20)
#   facet_ref_line_x <- c(20, 50, 80)
#
# ============================================================
# 2) Mean plot reference lines
# ============================================================
# These appear ONLY in the mean plot:
#   - structure/variant mean traces only
#
# No lines:
#   mean_ref_line_y <- NA
#   mean_ref_line_x <- NA
#
# One line:
#   mean_ref_line_y <- 10
#   mean_ref_line_x <- 50
#
# Multiple lines:
#   mean_ref_line_y <- c(10, 15, 20)
#   mean_ref_line_x <- c(20, 50, 80)
#
# ============================================================
# Important
# ============================================================
# Do NOT define the same variable multiple times:
#   facet_ref_line_y <- 10
#   facet_ref_line_y <- 20
# This will overwrite the first value and only 20 will be used.
#
# Use c(...) for multiple lines:
#   facet_ref_line_y <- c(10, 20)
#
# NA values are ignored:
