# ============================================================
# RMSD plotting script - detailed English commented version
# ============================================================
#
# WHAT THIS SCRIPT DOES
#   This script reads all extracted RMSD files from one selected folder,
#   automatically detects the structure name, optional subtype/pattern name,
#   and replicate number from each filename, and generates publication-style
#   plots.
#
# FILE NAMING RULE
#   Expected format:
#     YYYY-MM-DD_MAINSTRUCTURE[_SUBTYPE]_rX_RMSD.dat/csv
#
#   Example:
#     2026-04-27_NPG6-4_A0a_r1_RMSD.dat
#
#   Meaning:
#     2026-04-27  = file date. The script reads it but does not use it for grouping.
#     NPG6-4      = main structure category.
#     A0a         = optional subtype or linker pattern.
#     r1          = replicate ID.
#     RMSD       = analysis type.
#
# GROUPING RULE
#   Files are grouped by structure identity, not by date.
#   Therefore, files with different dates but the same structure/subtype are
#   automatically grouped together as replicates.
#
#   Example:
#     2026-04-20_NPG6-4_A0a_r1_RMSD.dat
#     2026-04-21_NPG6-4_A0a_r2_RMSD.dat
#     2026-04-27_NPG6-4_A0a_r3_RMSD.dat
#
#   These are treated as replicates of:
#     NPG6-4_A0a
#
# WHERE TO CHANGE COMMON SETTINGS
#   target_folder:
#     Change this to choose which date folder to analyze.
#
#   base_dir:
#     Change this if your RMSD folder is in a different location.
#
#   output_dir:
#     Change this if you want the figures saved somewhere else.
#
#   time_per_frame:
#     Change this if the frame-to-ns conversion changes.
#     Example:
#       1000 frames over 100 ns -> 0.1
#       2000 frames over 100 ns -> 0.05
#
#   x_min / x_max:
#     Controls the x-axis range shown in the final plot.
#     Example:
#       x_min <- -0.5
#       x_max <- 100.5
#     This gives a small margin before 0 ns and after 100 ns.
#
#   x_break_start / x_break_end / x_break_step:
#     Controls the x-axis tick marks.
#     Example:
#       x_break_start <- 0
#       x_break_end <- 100
#       x_break_step <- 10
#     This gives ticks at 0, 10, 20, ..., 100 ns.
#
#   y_min / y_max:
#     Controls the y-axis range shown in the final plot.
#
#   y_break_start / y_break_end / y_break_step:
#     Controls the y-axis tick marks.
#     Example:
#       y_break_start <- 0
#       y_break_end <- 30
#       y_break_step <- 5
#     This gives ticks at 0, 5, 10, ..., 30.
#
#   facet_width_per_panel:
#     Controls the width of each structure panel in the faceted plot.
#     Increase it if panels look too narrow.
#
#   manual_colors:
#     Set this to NULL for automatic colors.
#     Or manually specify colors like:
#       manual_colors <- c(
#         "NPG6-4_A0a" = "#E41A1C",
#         "NPG6-4_A1a" = "#377EB8"
#       )
#
# HOW TO RUN
#   In RStudio or R console:
#     source("path/to/this_script.R")
#
# ============================================================

# ============================================================
# RMSD plotting script for Desmond MD analysis
# Author: Sang Hoon Um
#
# Purpose
#   This script reads all RMSD .dat files from one analysis folder and
#   generates two publication-style plots:
#     1) Faceted plot: individual replicates + mean trace per structure
#     2) Mean plot: mean trace for each structure/variant on one panel
#
# Expected input folder
#   ~/Desktop/md_simulation/RMSD/<target_folder>/
#
# Expected input filename format
#   YYYY-MM-DD_MAINSTRUCTURE[_SUBTYPE]_rX_RMSD.dat
#
# Examples
#   2026-04-27_NPG6-4_r1_RMSD.dat
#   2026-04-27_NPG6-4_A0a_r1_RMSD.dat
#
# Metadata parsing rule
#   - The first field is treated as the date.
#   - The field matching r1, r2, r3, ... is treated as the replicate ID.
#   - The first field between date and replicate is the main structure.
#       Example: NPG6-4
#   - Any additional field between main structure and replicate is treated
#     as a subtype / pattern label.
#       Example: A0a
#
# Example parsing
#   2026-04-27_NPG6-4_A0a_r1_RMSD.dat
#     main structure = NPG6-4
#     subtype        = A0a
#     replicate      = r1
#
# Notes on color handling
#   - By default, colors are assigned automatically from the detected
#     structure/variant labels.
#   - To manually control colors for figures, define manual_colors below.
# ============================================================

# ----------------------------
# 0. Required packages
# ----------------------------
# install.packages("tidyverse")
# install.packages("janitor")

