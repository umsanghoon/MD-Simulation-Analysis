manual_colors <- NULL

# ----------------------------
# 2. Helper functions
# ----------------------------

read_dat <- function(path) {
  # Reads whitespace-delimited .dat files with a commented header line.
  # Example header:
  #   # frame rmsd_ca
  lines <- readLines(path)
  header_idx <- which(str_starts(lines, "\\s*#"))[1]
  if (is.na(header_idx)) {
    stop(paste("No header line beginning with # was found in:", path))
  }

  col_names <- lines[header_idx] |>
    str_remove("^\\s*#\\s*") |>
    str_split("\\s+") |>
    pluck(1) |>
    str_to_lower() |>
    str_replace_all("[^a-z0-9_]", "_")

  data_lines <- lines[(header_idx + 1):length(lines)]
  data_lines <- data_lines[str_detect(data_lines, "\\S")]

  read_table(
    I(data_lines),
    col_names = col_names,
    col_types = cols(.default = col_double()),
    show_col_types = FALSE
  )
}

parse_metadata <- function(filename, analysis_tag = "RMSD") {
  # Extracts date, main structure, subtype, and replicate from filename.
  name <- basename(filename)
  name <- str_remove(name, "\\.(dat|csv|xlsx)$")
  name <- str_remove(name, paste0("_", analysis_tag, "$"))
  parts <- str_split(name, "_", simplify = FALSE)[[1]]

  file_date <- parts[1]
  rep_idx <- which(str_detect(parts, "^r[0-9]+$"))
  if (length(rep_idx) == 0) {
    stop(paste("Could not find replicate ID such as r1/r2 in filename:", filename))
  }
  rep_idx <- rep_idx[length(rep_idx)]
  replicate <- parts[rep_idx]

  structure_parts <- parts[2:(rep_idx - 1)]
  if (length(structure_parts) < 1) {
    stop(paste("Could not identify structure name in filename:", filename))
  }

  treatment <- structure_parts[1]
  subtype <- if (length(structure_parts) >= 2) {
    paste(structure_parts[-1], collapse = "_")
  } else {
    NA_character_
  }

  tibble(
    source = basename(filename),
    file_date = file_date,
    treatment = treatment,
    subtype = subtype,
    replicate = replicate
  )
}

make_palette <- function(levels_vec, manual_colors = NULL) {
  # Creates an automatic palette and optionally overwrites selected colors
  # using manual_colors.
  auto <- setNames(rep(base_palette, length.out = length(levels_vec)), levels_vec)
  if (!is.null(manual_colors)) {
    matched <- intersect(names(manual_colors), names(auto))
    auto[matched] <- manual_colors[matched]
  }
  auto
}

add_structure_facet <- function(p, data) {
  # Uses nested facet strips when subtype exists.
  # If no subtype exists in the dataset, only the main structure strip is shown.
  if (any(!is.na(data$subtype) & data$subtype != "")) {
    p + facet_grid(. ~ treatment + subtype_plot, scales = "fixed")
  } else {
    p + facet_wrap(~ treatment, scales = "fixed", nrow = 1)
  }
}

make_ref_hline <- function(ref_values) {
  # Creates horizontal reference lines only when numeric values are provided.
  #
  # Examples:
  #   ref_line_y <- NA              -> no line
  #   ref_line_y <- 10              -> one line at y = 10
  #   ref_line_y <- c(10, 20, 30)   -> three horizontal lines
  ref_values <- ref_values[!is.na(ref_values)]
  if (length(ref_values) == 0) {
    return(NULL)
  }
  geom_hline(
    yintercept = ref_values,
    linetype = "dashed",
    color = "black",
    linewidth = 0.45,
    alpha = 0.8
  )
}

make_ref_vline <- function(ref_values) {
  # Creates vertical reference lines only when numeric values are provided.
  #
  # Examples:
  #   ref_line_x <- NA              -> no line
  #   ref_line_x <- 20              -> one line at x = 20 ns
  #   ref_line_x <- c(20, 50, 80)   -> three vertical lines
  ref_values <- ref_values[!is.na(ref_values)]
  if (length(ref_values) == 0) {
    return(NULL)
  }
  geom_vline(
    xintercept = ref_values,
    linetype = "dashed",
    color = "black",
    linewidth = 0.45,
    alpha = 0.8
  )
}

# ----------------------------
# 3. Locate RMSD files
# ----------------------------

folder_path <- file.path(path.expand(base_dir), target_folder)
if (!dir.exists(folder_path)) {
  stop(paste("Folder not found:", folder_path))
}

all_files <- list.files(
  folder_path,
  pattern = "RMSD\\.dat$",
  full.names = TRUE,
  ignore.case = TRUE
)
if (length(all_files) == 0) {
  stop(paste("No RMSD .dat files found in:", folder_path))
}

message(paste("Detected RMSD files:", length(all_files)))
message(paste(" ", basename(all_files), collapse = "\n  "))

# ----------------------------
# 4. Read and combine data
# ----------------------------

rmsd_data <- map_dfr(all_files, function(f) {
  meta <- parse_metadata(f, "RMSD")
  df <- read_dat(f) |> clean_names()

  df |> mutate(
    source = meta$source,
    file_date = meta$file_date,
    treatment = meta$treatment,
    subtype = meta$subtype,
    replicate = meta$replicate
  )
})

rmsd_candidates <- c("rmsd_ca", "prot_ca", "rmsd")
rmsd_col <- rmsd_candidates[rmsd_candidates %in% names(rmsd_data)][1]
if (is.na(rmsd_col) || is.null(rmsd_col)) {
  stop(paste("Could not find RMSD column. Available columns:", paste(names(rmsd_data), collapse = ", ")))
}

rmsd_data <- rmsd_data |>
  rename(rmsd = all_of(rmsd_col)) |>
  mutate(
    frame = as.numeric(frame),
    rmsd = as.numeric(rmsd),
    time_ns = frame * time_per_frame,
    subtype_plot = if_else(is.na(subtype), "", subtype),
    variant_label = if_else(is.na(subtype), treatment, paste(treatment, subtype, sep = "_"))
  )

variant_levels <- unique(rmsd_data$variant_label)
variant_palette <- make_palette(variant_levels, manual_colors)
n_panels <- n_distinct(rmsd_data$variant_label)
facet_width <- max(6, facet_width_per_panel * n_panels)

# Data used for replicate endpoint labels in the faceted plot.
# The script selects the last available point for each replicate near the
# end of the trajectory. These labels are not used in the mean-only plot.
replicate_label_data <- rmsd_data |>
  filter(time_ns <= x_max, time_ns >= (x_max - replicate_label_time_window)) |>
  group_by(source, treatment, subtype, subtype_plot, variant_label, replicate) |>
  slice_max(order_by = time_ns, n = 1, with_ties = FALSE) |>
  ungroup() |>
  mutate(
    # IMPORTANT:
    #   replicate_label_use_plain_number is a single TRUE/FALSE setting, not a
    #   column in the data frame. Therefore, use base R if/else here instead of
    #   dplyr::if_else().
    #
    #   If TRUE:
    #     r1, r2, r3, r4 are displayed as 1, 2, 3, 4.
    #   If FALSE:
    #     r1, r2, r3, r4 are displayed as r1, r2, r3, r4.
    replicate_label = if (replicate_label_use_plain_number) {
      str_remove(replicate, "^r")
    } else {
      replicate
    }
  )


# ----------------------------
# 5. Output folder
# ----------------------------

out_dir <- file.path(path.expand(output_dir), target_folder)
dir.create(out_dir, recursive = TRUE, showWarnings = FALSE)

# ----------------------------
# 6. Faceted RMSD plot
# ----------------------------

plot_facet_base <- ggplot(rmsd_data, aes(x = time_ns, y = rmsd)) +
  make_ref_hline(facet_ref_line_y) +
  make_ref_vline(facet_ref_line_x) +
  geom_line(aes(group = source, color = variant_label), alpha = line_alpha_replicate, linewidth = line_width_replicate) +
  {if (show_replicate_labels) geom_text(
    data = replicate_label_data,
    aes(x = time_ns, y = rmsd, label = replicate_label, color = variant_label),
    nudge_x = replicate_label_x_nudge,
    nudge_y = replicate_label_y_nudge,
    size = replicate_label_size,
    fontface = replicate_label_fontface,
    show.legend = FALSE
  )} +
  stat_summary(aes(group = variant_label, color = variant_label), fun = mean, geom = "line", linewidth = line_width_mean) +
  scale_color_manual(values = variant_palette, drop = FALSE) +
  scale_x_continuous(breaks = seq(x_break_start, x_break_end, by = x_break_step)) +
  scale_y_continuous(breaks = seq(y_break_start, y_break_end, by = y_break_step)) +
  coord_cartesian(xlim = c(x_min, x_max), ylim = c(y_min, y_max), clip = "off") +
  labs(
    title = paste("Protein RMSD -", target_folder),
    x = "Time (ns)",
    y = expression(RMSD~"(" * ring(A) * ")")
  ) +
  theme_classic(base_size = 14) +
  theme(
    legend.position = "none",
    axis.line = element_line(color = "black", linewidth = 0.8),
    panel.border = element_rect(color = "black", fill = NA, linewidth = 0.8),
    strip.background = element_rect(color = "black", fill = "grey95", linewidth = 0.8),
    strip.text = element_text(face = "bold", hjust = 0.5, margin = margin(4, 4, 4, 4)),
    panel.spacing.x = unit(0.18, "lines"),
    plot.margin = margin(5.5, 18, 5.5, 5.5)
  )

plot_facet <- add_structure_facet(plot_facet_base, rmsd_data)
print(plot_facet)

ggsave(
  file.path(out_dir, paste0(target_folder, "_RMSD_facet.png")),
  plot = plot_facet,
  width = facet_width,
  height = facet_height,
  dpi = 300,
  limitsize = FALSE
)

# ----------------------------
# 7. Mean RMSD plot
# ----------------------------

rmsd_mean <- rmsd_data |>
  group_by(variant_label, time_ns) |>
  summarise(rmsd_mean = mean(rmsd, na.rm = TRUE), .groups = "drop")

plot_mean <- ggplot(rmsd_mean, aes(x = time_ns, y = rmsd_mean, color = variant_label)) +
  make_ref_hline(mean_ref_line_y) +
  make_ref_vline(mean_ref_line_x) +
  geom_line(linewidth = line_width_mean) +
  scale_color_manual(values = variant_palette, drop = FALSE) +
  scale_x_continuous(breaks = seq(x_break_start, x_break_end, by = x_break_step)) +
  scale_y_continuous(breaks = seq(y_break_start, y_break_end, by = y_break_step)) +
  coord_cartesian(xlim = c(x_min, x_max), ylim = c(y_min, y_max)) +
  labs(
    title = paste("Protein RMSD Mean -", target_folder),
    x = "Time (ns)",
    y = expression(RMSD~"(" * ring(A) * ")"),
    color = NULL
  ) +
  theme_classic(base_size = 14) +
  theme(
    aspect.ratio = 1,
    legend.position = "right",
    legend.title = element_blank(),
    axis.line = element_line(color = "black", linewidth = 0.8),
    panel.border = element_rect(color = "black", fill = NA, linewidth = 0.8)
  )

print(plot_mean)

ggsave(
  file.path(out_dir, paste0(target_folder, "_RMSD_mean.png")),
  plot = plot_mean,
  width = mean_width,
  height = mean_height,
  dpi = 300
)

message(paste("RMSD analysis completed:", out_dir))
